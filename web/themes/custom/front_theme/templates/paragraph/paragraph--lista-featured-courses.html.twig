{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}

{% set view_name = 'list_featured_courses' %}
{% set view_block = 'block_1' %}

{% set results = drupal_view_result(view_name, view_block) %}

{% if results|length > 0 %}
  <div{{ attributes.addClass(classes) }}>
    <h3>{{ paragraph.field_section_title.value }}</h3>
    <p>{{ paragraph.field_text.value }}</p>
    {{ drupal_view(view_name, view_block) }}
  </div>
{% endif %}
