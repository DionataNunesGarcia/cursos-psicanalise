
{% set side = content.field_side_of_the_image[0]['#markup'] %}
{% set background = content.field_class_background[0]['#context']['value'] %}
<div class="bg-{{ background }}">
  {%
    set classes = [
      'container mx-auto px-4 py-12',
      'paragraph',
      'paragraph--type--' ~ paragraph.bundle|clean_class,
      view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
      not paragraph.isPublished() ? 'paragraph--unpublished',
      'paragraph-bg-' ~ background
    ]
  %}
  {% block paragraph %}
    {{dump(background)}}
    {{dump(content)}}
    <div{{ attributes.addClass(classes) }}>
      <div class="flex flex-col md:flex-row items-center gap-10">
        {# IMAGEM #}
        <div class="
          w-full md:w-1/2
          {{ side == 'right' ? 'md:order-2' : 'md:order-1' }}
        ">
          {{ content.field_image }}
        </div>

        {# TEXTO #}
        <div class="
          w-full md:w-1/2
          {{ side == 'right' ? 'md:order-1' : 'md:order-2' }}
        ">
          <h3 class="text-2xl font-semibold mb-4">
            {{ content.field_section_title[0]['#context']['value'] }}
          </h3>

          {% if content.field_body[0] is defined %}
            <div class="text-base leading-relaxed">
              {{ content.field_body }}
            </div>
          {% endif %}

          {% if content.field_link[0] is defined %}
            <div class="mt-4">
              {{ content.field_link }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endblock paragraph %}
</div>
