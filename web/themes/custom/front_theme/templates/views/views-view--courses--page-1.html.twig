{#
/**
 * View: contents by category (block_1)
 */
#}
<section class="relative pt-20 pb-20 px-6 lg:px-12 bg-stone-50 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <svg class="w-full h-full text-emerald-900" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern id="trianglePattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M20,0 L40,40 L0,40 Z" fill="currentColor" opacity="0.03"></path>
          <path d="M0,0 L20,0 L0,20 Z" fill="currentColor" opacity="0.03"></path>
          <path d="M40,0 L40,20 L20,0 Z" fill="currentColor" opacity="0.03"></path>
        </pattern>
      </defs>
      <rect width="200" height="200" fill="url(#trianglePattern)"></rect>
    </svg>
  </div>
  <div class="container px-6 2xl:px-0 mx-auto max-w-[1400px] mx-auto relative z-1₀">
    <div class="max-w-3xl">
      <div class="w-16 h-1 bg-amber-600 mb-6"></div>
      <h1 class="font-serif text-5xl lg:text-7xl leading-[1.1] tracking-tight mb-6">
        {{ 'Nossos Cursos'|t }}
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed">
        {{ 'Programas cuidadosamente elaborados que integram a teoria psicanalítica com a consciência cultural e a prática contemporânea em saúde mental.'|t }}
      </p>
    </div>
  </div>
</section>
<section class="py-12 px-6 lg:px-12 border-b border-neutral-200 sticky top-20 bg-white/95 backdrop-blur-sm z-40">
  <div class="max-w-[1400px] mx-auto">
    <div class="space-y-6">
      <div class="relative flex flex-col items-start sm:items-center gap-4 justify-between">
        {{ exposed }}
      </div>
    </div>
  </div>
</section>
<section class="container py-20 px-6 2xl:px-0 mx-auto max-w-[1400px]">
  <div id="{{ view.dom_id }}" class="js-view-dom-id-{{ view.dom_id }}">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-10">
      {{ rows }}
    </div>
  </div>
  
  {# Paginação #}
  {% if pager %}
    <div class="mt-12 flex justify-center">
      {{ pager }}
    </div>
  {% endif %}
</section>
