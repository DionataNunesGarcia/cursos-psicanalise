<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>

    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">

  </head>

  <body{{ attributes.addClass(
      logged_in ? 'user-logged-in',
      root_path ? 'path-' ~ root_path|clean_class,
      node_type ? 'node-' ~ node_type|clean_class,
    ) }}>

    <a href="#main-content" class="visually-hidden focusable">
      Skip to main content
    </a>

    {{ page_top }}
    {{ page }}
    {{ page_bottom }}

    <js-bottom-placeholder token="{{ placeholder_token }}">
    <div id="page-loader" class="fixed inset-0 z-[9999] bg-white flex items-center justify-center">

      <div class="space-y-4 animate-pulse">
        
        <div class="h-6 w-40 bg-neutral-200 rounded"></div>
        <div class="h-4 w-64 bg-neutral-200 rounded"></div>
        <div class="h-4 w-52 bg-neutral-200 rounded"></div>

      </div>

    </div>
  </body>
</html>
