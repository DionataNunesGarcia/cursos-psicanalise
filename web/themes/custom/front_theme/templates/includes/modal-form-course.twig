{# modal-subscription.twig #}
<div id="course-subscription-modal" class="fixed inset-0 bg-black/50 flex items-center rounded-none justify-center z-50 hidden">
  <div class="bg-white rounded-none max-w-3xl w-full px-6 py-8 relative">
    
    <!-- Botão de fechar -->
    <button id="modal-close-btn"
            class="absolute top-4 right-4 text-gray-600 hover:text-gray-900 text-3xl font-bold">&times;</button>
    
    <!-- Título -->
    <h2 class="text-2xl font-semibold mb-4 text-center">Inscreva-se no curso</h2>
    <h3 class="text-3xl font-semibold mb-4 text-center">{{label}}</h3>
    <hr class="mb-6 border-gray-300">

    <!-- Webform -->
    {{ drupal_entity('webform', 'course_subscribe') }}

  </div>
</div>