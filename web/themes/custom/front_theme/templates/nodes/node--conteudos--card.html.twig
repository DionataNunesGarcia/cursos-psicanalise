<article class="bg-white shadow-xl flex flex-col h-full">

  {# Imagem com margin #}
  {% if content.field_thumbnail_image %}
    <div class="p-4">
      <div class="overflow-hidden">
        {{ content.field_thumbnail_image }}
      </div>
    </div>
  {% endif %}

  <div class="px-4 pb-4 flex flex-col flex-1">

    {# Data + tempo de leitura #}
    <div class="text-xs text-gray-500 mb-2">
      {{ node.created.value|format_date('custom', 'd M Y', null, 'pt-br') }} • {{ reading_time }} min de leitura
    </div>

    {# Título #}
    <h3 class="text-lg font-semibold mb-2">
      <a href="{{ url }}" class="hover:underline">
        {{ label }}
      </a>
    </h3>

    {# Resumo #}
    {% if content.body %}
      <div class="text-gray-600 text-sm mb-4 line-clamp-3">
        {{ content.body }}
      </div>
    {% endif %}

    {# Autor #}
    {% if node.field_author.entity %}
      {% set author = node.field_author.entity %}
      <div class="flex items-center gap-2 mb-3">

        {# imagem do autor (ajusta o campo se necessário) #}
        {% if author.field_image %}
          <div class="w-8 h-8 rounded-full overflow-hidden">
            {{ author.field_image.entity.field_media_image }}
          </div>
        {% endif %}

        <span class="text-sm text-gray-700">
          {{ author.label }}
        </span>
      </div>
    {% endif %}

    {# Tags #}
    {% if content.field_tags %}
      <div class="flex flex-wrap gap-2 mt-auto">
        {{ content.field_tags }}
      </div>
    {% endif %}

  </div>

</article>
